rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // -------------------------------------------------------------------------
    // 1. GLOBAL HELPERS
    // -------------------------------------------------------------------------
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == "lohdexstex22@gmail.com" ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isSignedInVerified() {
      return isAuthenticated() && request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // -------------------------------------------------------------------------
    // 2. ENTITY VALIDATIONS
    // -------------------------------------------------------------------------
    
    function isValidGameState(data) {
      let requiredFields = ['uid', 'persona', 'stats', 'day', 'saveSlot'];
      return data.keys().hasAll(requiredFields) &&
             data.uid == request.auth.uid &&
             data.stats is map &&
             data.day is int && 
             data.saveSlot is int;
    }

    function isValidLeaderboard(data) {
      let requiredFields = ['uid', 'displayName', 'score', 'persona', 'daysSurvived', 'timestamp'];
      return data.keys().hasAll(requiredFields) &&
             data.uid == request.auth.uid &&
             data.score is number &&
             data.timestamp == request.time;
    }

    // -------------------------------------------------------------------------
    // 3. COLLECTION RULES
    // -------------------------------------------------------------------------

    // Global default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Users and their slots
    // Flat path matching for clarity
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
    }

    match /users/{userId}/slots/{slotId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidId(slotId) && isValidGameState(incoming());
      allow update: if isOwner(userId) && isValidId(slotId) && isValidGameState(incoming());
      allow delete: if isOwner(userId) || isAdmin();
    }

    // Leaderboard
    match /leaderboard/{entryId} {
      // Use permissive read for global visibility, but enforce it's a read
      allow read: if isAuthenticated();
      
      // Still enforce secure creation
      allow create: if isSignedInVerified() && isValidLeaderboard(incoming());
      allow update, delete: if isAdmin();
    }
  }
}
